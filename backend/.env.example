# --- AI Provider (pick one) ---

# Option A: OpenRouter (recommended — supports many models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Option B: Direct OpenAI
OPENAI_API_KEY=

# Override the AI model (optional)
# OpenRouter format: "openai/gpt-4o-mini", "anthropic/claude-3-haiku"
# Direct OpenAI format: "gpt-4o-mini"
AI_MODEL=openai/gpt-oss-120b:free

# Server port
PORT=3000

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/webfixer
# For MongoDB Atlas use: mongodb+srv://<username>:<password>@cluster.mongodb.net/webfixer

# Rate Limiting (Redis)
# Leave REDIS_URL empty to fallback to memory store (free/local testing)
REDIS_URL=
